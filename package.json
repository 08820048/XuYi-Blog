{
  "name": "qiaomu-blog-opensource",
  "version": "0.1.0",
  "private": false,
  "scripts": {
    "dev": "next dev",
    "build": "if [ \"$OPENNEXT_INTERNAL_BUILD\" = \"1\" ]; then next build; else OPENNEXT_INTERNAL_BUILD=1 opennextjs-cloudflare build; fi",
    "build:next": "next build",
    "test": "vitest",
    "test:run": "vitest run",
    "verify": "bash scripts/verify.sh full",
    "verify:quick": "bash scripts/verify.sh quick",
    "preview": "bash scripts/cf-preview.sh",
    "preview:remote": "PREVIEW_REMOTE=1 bash scripts/cf-preview.sh",
    "deploy": "bash scripts/cf-deploy.sh",
    "worktree:add": "bash scripts/worktree-add.sh",
    "worktree:prune": "git worktree prune",
    "cf-typegen": "bash scripts/cf-typegen.sh",
    "cf:init": "bash scripts/cf-init.sh",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.1",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-code-block-lowlight": "^3.22.4",
    "@tiptap/extension-image": "^3.22.3",
    "@tiptap/extension-table": "^3.22.3",
    "@tiptap/extension-table-cell": "^3.22.3",
    "@tiptap/extension-table-header": "^3.22.3",
    "@tiptap/extension-table-row": "^3.22.3",
    "@tiptap/extension-youtube": "^3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@types/turndown": "^5.0.6",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "html2pdf.js": "^0.14.0",
    "juice": "^11.1.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.8.0",
    "nanoid": "^5.1.7",
    "next": "16.2.3",
    "novel": "^1.0.2",
    "openai": "^6.34.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.7",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "tiptap-extension-auto-joiner": "^0.1.3",
    "tiptap-markdown": "^0.9.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5",
    "wrangler": "^4.84.1"
  },
  "description": "Open-source Cloudflare blog starter with Next.js 16, D1, R2, built-in themes, and AI provider presets.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/08820048/XuYi-Blog.git"
  },
  "homepage": "https://github.com/08820048/XuYi-Blog",
  "bugs": {
    "url": "https://github.com/08820048/XuYi-Blog/issues"
  },
  "cloudflare": {
    "bindings": {
      "NEXT_PUBLIC_SITE_URL": {
        "description": "你的博客公网域名，例如 `https://blog.example.com`。"
      },
      "ADMIN_PASSWORD": {
        "description": "后台 `/admin` 登录密码。请使用高强度独立密码。"
      },
      "ADMIN_TOKEN_SALT": {
        "description": "管理员 Token 签名盐。可用 `openssl rand -hex 32` 生成。"
      },
      "NEXT_PUBLIC_SITE_NAME": {
        "description": "站点显示名称，例如 `XuYi博客`。"
      },
      "AI_CONFIG_ENCRYPTION_SECRET": {
        "description": "用于加密保存 AI 供应商 Key。可用 `openssl rand -hex 32` 生成。"
      },
      "AI_API_KEY": {
        "description": "可选。外部 AI 服务的 API Key，用于文本生成或生图能力。"
      },
      "FEISHU_BOT_WEBHOOK": {
        "description": "飞书自定义机器人 Webhook，用于每天 08:00、12:00、23:00 推送博客数据报告。"
      },
      "FEISHU_BOT_SECRET": {
        "description": "可选。飞书自定义机器人签名密钥；机器人开启签名校验时填写。"
      },
      "FEISHU_REPORT_SITE_NAME": {
        "description": "可选。飞书数据报告里显示的站点名称，默认使用 `XuYi博客`。"
      }
    }
  }
}
